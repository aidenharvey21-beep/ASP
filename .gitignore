```gitignore
#========================================================#
# AirSupportPro
# Git Ignore Configuration
# Version: 0.1.0
#
# Prevents unnecessary files from being committed.
#========================================================#


#--------------------------------------------------------#
# Operating System Files
#--------------------------------------------------------#

.DS_Store
Thumbs.db
desktop.ini


#--------------------------------------------------------#
# Editors / IDEs
#--------------------------------------------------------#

.vscode/
.idea/

*.sublime-project
*.sublime-workspace


#--------------------------------------------------------#
# Lua Development
#--------------------------------------------------------#

*.luac

luac.out


#--------------------------------------------------------#
# FiveM Cache / Runtime Files
#--------------------------------------------------------#

cache/
server-cache/
server-cache-priv/

crashes/

logs/


#--------------------------------------------------------#
# Node / NUI Development
#--------------------------------------------------------#

node_modules/

npm-debug.log*
yarn-debug.log*
yarn-error.log*


#--------------------------------------------------------#
# Build Files
#--------------------------------------------------------#

dist/
build/

*.zip
*.rar
*.7z


#--------------------------------------------------------#
# Temporary Files
#--------------------------------------------------------#

*.tmp
*.temp

*.bak

*.old


#--------------------------------------------------------#
# Environment / Secrets
#--------------------------------------------------------#

.env

.env.*

secrets/

credentials/


#--------------------------------------------------------#
# Testing
#--------------------------------------------------------#

test-results/

coverage/


#--------------------------------------------------------#
# Screenshots / Development Media
#--------------------------------------------------------#

screenshots/temp/

recordings/


#--------------------------------------------------------#
# Local Configuration
#--------------------------------------------------------#

local_config.lua
config.local.lua
```
